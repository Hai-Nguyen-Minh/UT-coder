# Một config.json duy nhất được dùng cho mọi môi trường.
# Chỉ tạo file .env khi cần ghi đè các giá trị mặc định dưới đây.

UTCODER_OLLAMA_BASE_URL=http://localhost:11434
UTCODER_LLM_MODEL=qwen2.5-coder:7b
UTCODER_LLM_TEMPERATURE=0.1
UTCODER_CHROMA_DIR=./chroma_db
UTCODER_EMBEDDING_MODEL=nomic-embed-text

# REST API cho VS Code extension. Ở server hybrid nên giữ host loopback và
# truy cập qua: ssh -N -L 8000:127.0.0.1:8000 <user>@<server-ip>
UTCODER_API_HOST=127.0.0.1
UTCODER_API_PORT=8000
UTCODER_API_TOKEN=
UTCODER_API_MAX_REQUEST_BYTES=2097152

# Giới hạn evaluator/mutation trên server
UTCODER_EVAL_COMPILE_TIMEOUT=10
UTCODER_EVAL_COLLECTION_TIMEOUT=30
UTCODER_EVAL_BASELINE_TIMEOUT=30
UTCODER_EVAL_COVERAGE_TIMEOUT=45
UTCODER_EVAL_MEMORY_MB=768
UTCODER_EVAL_MUTATION_TIMEOUT=180
UTCODER_EVAL_MUTATION_CHILDREN=2
UTCODER_EVAL_MUTATION_MEMORY_MB=1536
UTCODER_EVAL_MAX_PROCESSES=32
